# .gitignore - common entries for a website/codebase

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json.gz

# Build / output
dist/
build/
out/
public/build/
.cache/
.next/
.umi/
.astro/
.svelte-kit/
.parcel-cache/
.vite/

# Environment / secrets
.env
.env.*.local
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
secrets.json

# Logs and runtime
logs/
*.log
pids/
*.pid
*.seed
*.pid.lock
tmp/
temp/

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# IDE / editors
.vscode/
.idea/
.project
*.sublime-workspace
*.sublime-project
*.code-workspace

# Tests / coverage
coverage/
.nyc_output/
coverage-final.json
jest-cache/
.vitest/

# Compiled files / caches
*.tsbuildinfo
.cache-loader/
.cache/
.sass-cache/

# Generated assets / maps
*.map
*.bundle.js
*.min.js
*.min.css

# Backup / swap files
*~
*.swp
*.swo
*.bak
*.orig

# Docker
docker-compose.override.yml
.env.docker

# Misc
node-debug.log
dist-*/ 
uploads/
.Dockerfile.swp